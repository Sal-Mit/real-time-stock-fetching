{
  "name": "crypto-price-streaming-app",
  "version": "1.0.0",
  "private": true,
  "description": "Fullstack cryptocurrency price streaming application using Next.js, Node.js, ConnectRPC, and Playwright",
  "scripts": {
    "dev": "./run.sh",
    "dev:backend": "pnpm -F @crypto-app/backend dev",
    "dev:frontend": "pnpm -F @crypto-app/frontend dev",
    "build": "pnpm -r build",
    "build:backend": "pnpm -F @crypto-app/backend build",
    "build:frontend": "pnpm -F @crypto-app/frontend build",
    "clean": "pnpm -r clean",
    "clean:all": "pnpm -r clean && rm -rf node_modules",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint --fix",
    "format": "prettier --write .",
    "proto:generate": "cd packages/proto && buf generate",
    "install:all": "pnpm install --recursive",
    "type-check": "pnpm -r type-check"
  },
  "devDependencies": {
    "@types/node": "^20.19.11",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "eslint": "^9.34.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
